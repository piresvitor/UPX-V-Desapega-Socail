{
  "expo": {
    "name": "Desapega Social",
    "slug": "desapega-social",
    "version": "1.0.0",
    "scheme": "desapegasocial",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#EB681E" 
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.desapegasocial"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.desapegasocial",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
        "apiKey": "CHAVE_FALSA_APENAS_PARA_EVITAR_CRASH"        }
      }
    },
    "web": { "favicon": "./assets/favicon.png" },
    "extra": {
      "eas": { "projectId": "4c4bfa66-1d53-4432-a1b3-fcac0b31d4dd" }
    }
  }
}